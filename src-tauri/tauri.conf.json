{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ai-searcher",
  "version": "0.3.2",

  "identifier": "com.a1595.ai-searcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AI Searcher",
        "width": 750,
        "height": 84,
        "minWidth": 400,
        "minHeight": 80,
        "maxWidth": 1200,
        "maxHeight": 900,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": false,
        "x": 600,
        "y": 100,
        "skipTaskbar": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
